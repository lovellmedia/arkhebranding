---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Home Services Branding - Tools & Resources";
const description = "Brand assessment frameworks, marketing ROI calculators, and resources for building effective home services brands.";
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<BaseLayout title={title} description={description} canonicalURL={canonicalURL}>
  <article>
    <h1>Tools & Resources for Home Services Branding</h1>
    
    <section>
      <h2>Tool 1: Brand Health Scorecard</h2>
      <p>Use this scorecard to assess the current state of your home services brand across all key dimensions.</p>
      <div class="tool-box">
        <h3>Visual Identity (0–25 points)</h3>
        <ul>
          <li><strong>Professional logo that works at all sizes (van to business card):</strong> +5 pts</li>
          <li><strong>Consistent color scheme used across all materials:</strong> +5 pts</li>
          <li><strong>Branded uniforms for all field technicians:</strong> +5 pts</li>
          <li><strong>At least one wrapped vehicle in fleet:</strong> +5 pts</li>
          <li><strong>Professional yard signs or job site signage:</strong> +5 pts</li>
        </ul>
        <h3>Digital Presence (0–25 points)</h3>
        <ul>
          <li><strong>Website loads in under 3 seconds on mobile:</strong> +5 pts</li>
          <li><strong>Google Business Profile fully completed with photos:</strong> +5 pts</li>
          <li><strong>50+ Google reviews averaging 4.5 stars or above:</strong> +5 pts</li>
          <li><strong>Click-to-call button prominent on all pages:</strong> +5 pts</li>
          <li><strong>Active social media with regular posts:</strong> +5 pts</li>
        </ul>
        <h3>Reputation & Trust (0–25 points)</h3>
        <ul>
          <li><strong>Systematic post-job review request process in place:</strong> +5 pts</li>
          <li><strong>All reviews (positive and negative) receive responses:</strong> +5 pts</li>
          <li><strong>BBB accreditation or equivalent trust certification:</strong> +5 pts</li>
          <li><strong>Licensed & insured badges prominently displayed:</strong> +5 pts</li>
          <li><strong>Background check badges for technicians:</strong> +5 pts</li>
        </ul>
        <h3>Customer Experience (0–25 points)</h3>
        <ul>
          <li><strong>Technicians introduce themselves and wear shoe covers:</strong> +5 pts</li>
          <li><strong>Upfront, written pricing before work begins:</strong> +5 pts</li>
          <li><strong>Follow-up call or text after job completion:</strong> +5 pts</li>
          <li><strong>Maintenance plan or loyalty program offered:</strong> +5 pts</li>
          <li><strong>Referral program with incentives:</strong> +5 pts</li>
        </ul>
        <p><strong>Score 85–100:</strong> Strong brand — focus on growth. <strong>60–84:</strong> Solid foundation — fill the gaps. <strong>Below 60:</strong> Urgent brand investment needed.</p>
      </div>
    </section>

    <section>
      <h2>Tool 2: Marketing Channel ROI Estimator</h2>
      <p>Evaluate which marketing channels deserve your budget based on average home services industry performance data.</p>
      <div class="tool-box">
        <div class="tool-input">
          <label for="channel">Select a marketing channel:</label>
          <select id="channel">
            <option value="referral">Customer Referrals</option>
            <option value="google-lsa">Google Local Services Ads</option>
            <option value="google-ppc">Google PPC Ads</option>
            <option value="seo">Local SEO / Organic Search</option>
            <option value="direct-mail">Direct Mail</option>
            <option value="social">Social Media Ads</option>
            <option value="nextdoor">Nextdoor Ads</option>
          </select>
          <label for="monthlyBudget">Monthly budget ($):</label>
          <input type="number" id="monthlyBudget" value="1000" min="100" max="50000">
          <button onclick="calcROI()">Estimate ROI</button>
        </div>
        <div id="roiResult" class="tool-output" style="display:none;">
          <h4>Estimated Performance</h4>
          <p id="roiEstimate"></p>
          <p id="roiNote"></p>
        </div>
      </div>
    </section>

    <section>
      <h2>Top Recommended Resources by Category</h2>
      <ul>
        <li><strong>Reputation management:</strong> Podium, Birdeye, NiceJob — automated review request platforms</li>
        <li><strong>Local SEO tracking:</strong> BrightLocal — rank tracking, citation audits, review monitoring</li>
        <li><strong>Website for home services:</strong> Scorpion, Rival Digital, Hatch — specialists in home services web design and SEO</li>
        <li><strong>Call tracking & analytics:</strong> CallRail — track which marketing sources drive calls and conversions</li>
        <li><strong>CRM & dispatch:</strong> ServiceTitan, Jobber, Housecall Pro — purpose-built for home services operations</li>
        <li><strong>Google Ads management:</strong> WorkIZ, Sightly — home services PPC specialists</li>
        <li><strong>Direct mail:</strong> ValPak, MailShark, Taradel — targeted home services direct mail platforms</li>
      </ul>
    </section>

    <section>
      <h2>Exploring Further</h2>
      <p>For more context on home services branding:</p>
      <ul>
        <li>Review the <a href="/home-services-branding/">overview</a> of branding fundamentals</li>
        <li>Understand the <a href="/home-services-branding/technical-deep-dive/">technical brand systems</a> behind these tools</li>
        <li>Explore <a href="/home-services-branding/ontology/">detailed terminology</a> in our knowledge base</li>
        <li>Address <a href="/home-services-branding/challenges/">common branding challenges</a></li>
      </ul>
    </section>
  </article>

  <style>
    article {
      max-width: 900px;
      margin: 0 auto;
    }

    h1 {
      font-size: 2rem;
      margin-bottom: 1.5rem;
      color: #2c3e50;
    }

    h2 {
      font-size: 1.5rem;
      margin-top: 2rem;
      margin-bottom: 1rem;
      color: #34495e;
      border-bottom: 2px solid #667eea;
      padding-bottom: 0.5rem;
    }

    h3 {
      font-size: 1.2rem;
      margin-top: 1rem;
      color: #555;
    }

    section {
      margin-bottom: 2rem;
    }

    p {
      margin-bottom: 1rem;
      line-height: 1.8;
      color: #444;
    }

    .tool-box {
      background: #f9f9f9;
      border: 1px solid #ddd;
      border-radius: 8px;
      padding: 1.5rem;
      margin: 1.5rem 0;
    }

    .tool-input {
      background: white;
      padding: 1rem;
      border-radius: 4px;
      margin: 1rem 0;
    }

    .tool-input label {
      display: block;
      margin-top: 1rem;
      margin-bottom: 0.5rem;
      font-weight: 500;
      color: #333;
    }

    .tool-input input,
    .tool-input textarea,
    .tool-input select {
      width: 100%;
      padding: 0.5rem;
      border: 1px solid #ddd;
      border-radius: 4px;
      font-family: inherit;
      font-size: 1rem;
    }

    .tool-input textarea {
      min-height: 80px;
      resize: vertical;
    }

    .tool-input button {
      margin-top: 1rem;
      padding: 0.75rem 1.5rem;
      background-color: #667eea;
      color: white;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-size: 1rem;
      font-weight: 500;
    }

    .tool-input button:hover {
      background-color: #764ba2;
    }

    .tool-output {
      background: #e8f4f8;
      padding: 1rem;
      border-radius: 4px;
      border-left: 4px solid #667eea;
      margin-top: 1rem;
    }

    .tool-output h4 {
      color: #667eea;
      margin-top: 0;
    }

    .tool-output p {
      margin-bottom: 0.5rem;
    }

    .tool-output ul {
      margin-left: 1.5rem;
    }

    .tool-output li {
      margin-bottom: 0.5rem;
    }

    ul {
      margin-left: 2rem;
      margin-bottom: 1rem;
    }

    li {
      margin-bottom: 0.5rem;
      line-height: 1.6;
      color: #444;
    }

    a {
      color: #667eea;
      text-decoration: none;
      border-bottom: 1px dotted #667eea;
    }

    a:hover {
      color: #764ba2;
      border-bottom-color: #764ba2;
    }
  </style>

  <script is:inline>
    function analyzeSentence() {
      const sentence = document.getElementById('sentence').value;
      if (!sentence) {
        alert('Please enter a sentence');
        return;
      }
      
      const result = document.getElementById('analysisResult');
      document.getElementById('errorExplanation').textContent = 'Example: "He go" - Missing third-person singular marker (-s)';
      document.getElementById('slaExplanation').textContent = 'SLA Principle: Incomplete learning of morphosyntax. The learner has not yet internalized the rule that third-person singular present tense requires -s.';
      document.getElementById('suggestion').textContent = 'Suggestion: Focus on input containing third-person singular forms. Notice the pattern: "He goes, She goes, It goes." Practice producing sentences with this structure.';
      result.style.display = 'block';
    }

    function matchLearningCondition() {
      const age = document.getElementById('age').value;
      const time = document.getElementById('time').value;
      const context = document.getElementById('context').value;
      
      const result = document.getElementById('matchResult');
      document.getElementById('matchExplanation').textContent = 'Based on your learning context, here are personalized recommendations from SLA research:';
      
      const recommendations = document.getElementById('recommendations');
      recommendations.innerHTML = '';
      
      const recs = [
        'Prioritize comprehensible input: Read and listen to content slightly above your level',
        'Engage in meaningful interaction: Seek conversation partners or language exchange',
        'Practice output regularly: Speak and write daily, even if just for 15 minutes',
        'Use spaced repetition for vocabulary: Review new words at increasing intervals',
        'Lower your affective filter: Create a supportive learning environment, reduce anxiety'
      ];
      
      recs.forEach(rec => {
        const li = document.createElement('li');
        li.textContent = rec;
        recommendations.appendChild(li);
      });
      
      result.style.display = 'block';
    }

    function calculateVocabTimeline() {
      const targetVocab = parseInt(document.getElementById('targetVocab').value);
      const hoursPerWeek = parseInt(document.getElementById('hoursPerWeek').value);
      
      if (!targetVocab || !hoursPerWeek) {
        alert('Please enter valid numbers');
        return;
      }
      
      // Based on Nation's research: ~100-150 words per 10 hours of study
      const wordsPerHour = 12.5;
      const totalHours = targetVocab / wordsPerHour;
      const weeks = totalHours / hoursPerWeek;
      const months = weeks / 4.3;
      
      const result = document.getElementById('vocabResult');
      document.getElementById('timelineExplanation').textContent = 'Based on research by Paul Nation and others:';
      document.getElementById('timelineResult').textContent = `To acquire ${targetVocab} words at ${hoursPerWeek} hours/week: approximately ${Math.round(weeks)} weeks (${Math.round(months)} months)`;
      document.getElementById('timelineNote').textContent = 'Note: This assumes quality study (spaced repetition, meaningful use). Actual timeline varies based on motivation, learning strategies, and exposure to authentic input.';
      result.style.display = 'block';
    }
  </script>
</BaseLayout>
